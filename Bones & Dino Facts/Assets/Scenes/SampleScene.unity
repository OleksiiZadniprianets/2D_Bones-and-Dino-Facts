  m_Script: {fileID: 11500000, guid: 67ec5d6fd76fa4f4892192cdf49c6fac, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  factText: {fileID: 1772232225}
  scoreText: {fileID: 874875211}
  dinosaurs:
  - name: Tyrannosaurus rex
    skeleton: {fileID: 21300000, guid: 015ff8f2a8275424594466d8539c3774, type: 3}
    real: {fileID: 21300000, guid: 22b827a2ff118ad45a8039b6fbfa0a6a, type: 3}
    factEasy: Was a large carnivorous dinosaur
    factMedium: "It lived during the Late Cretaceous period, about 68\u201366 million
      years ago"
    factHard: Had one of the strongest bite forces of any land animal ever, estimated
      at over 30,000 newtons
  - name: Triceratops
    skeleton: {fileID: 21300000, guid: 3a3c81278ab22d3488292bda04c60ec4, type: 3}
    real: {fileID: 21300000, guid: 0b0381ba6088bc34cac733343c4e74d2, type: 3}
    factEasy: Had three horns on its head
    factMedium: It used its horns and frill for defense against predators
    factHard: Its frill may have also been used for display or temperature regulation
  - name: Velociraptor
    skeleton: {fileID: 21300000, guid: 9e184b725fefd324c81f670addb222a0, type: 3}
    real: {fileID: 21300000, guid: 319b97de7ad01434292834fa53bb45f5, type: 3}
    factEasy: Was a small, fast predator
    factMedium: It had a large sickle-shaped claw on each foot
    factHard: Evidence suggests they had feathers, making them closer to birds than
      reptiles in appearance
  - name: Brachiosaurus
    skeleton: {fileID: 21300000, guid: dd43dd8e07f8c9f46ba7e2b917d403e6, type: 3}
    real: {fileID: 21300000, guid: e181779b1b565e14d89a584d0bed6c09, type: 3}
    factEasy: Was a very tall dinosaur with a long neck
    factMedium: It was a herbivore that fed on leaves from tall trees
    factHard: Unlike most dinosaurs, its front legs were longer than its hind legs,
      giving it a giraffe-like posture
  - name: Stegosaurus
    skeleton: {fileID: 21300000, guid: cd123671e7d31c947be12d3e368313db, type: 3}
    real: {fileID: 21300000, guid: 7a2d3bc549cf53b4e8e0c116cbf750c5, type: 3}
    factEasy: Had large plates along its back
    factMedium: "It had spikes on its tail, often called a \u201Cthagomizer\u201D"
    factHard: Its brain was relatively small compared to its body size, about the
      size of a walnut
  - name: Spinosaurus
    skeleton: {fileID: 21300000, guid: 149dc098c9e6172498a3fe04d7c78e1e, type: 3}
    real: {fileID: 21300000, guid: 6d3a813f67fcfb44a9712d800dd6b61d, type: 3}
    factEasy: Had a large sail on its back
    factMedium: It likely spent much of its time in water
    factHard: It is considered the largest known carnivorous dinosaur
  - name: Ankylosaurus
    skeleton: {fileID: 21300000, guid: 8b4881b1085f790409b39a7eaa72f046, type: 3}
    real: {fileID: 21300000, guid: 5748d756829c0a342a398bad94f9c2d6, type: 3}
    factEasy: Was covered in armor
    factMedium: It had a large club at the end of its tail for defense
    factHard: Its armor included bony plates called osteoderms embedded in its skin
  - name: Diplodocus
    skeleton: {fileID: 21300000, guid: 02965370bdda4074c9157c9c1d07bc84, type: 3}
    real: {fileID: 21300000, guid: 64c471a0899722e409535179c2785961, type: 3}
    factEasy: Had a very long neck and tail
    factMedium: It was one of the longest dinosaurs ever discovered
    factHard: Its tail may have been used like a whip to make loud sounds
  - name: Allosaurus
    skeleton: {fileID: 21300000, guid: c3df3ecc45eaa4c41b9edaa7f5bc4fb6, type: 3}
    real: {fileID: 21300000, guid: af2d39994965d7a42912294df656cc47, type: 3}
    factEasy: Had two small ridges above its eyes
    factMedium: It lived before most predators, during the Jurassic period
    factHard: Often found with herbivores fossils, suggesting they lived in the same
      environment
  - name: Parasaurolophus
    skeleton: {fileID: 21300000, guid: 77ce30e8e4cb721428c76fb761ad2169, type: 3}
    real: {fileID: 21300000, guid: 34b8d3cd59ecece4bbeff74b2f787db0, type: 3}
    factEasy: Had a long, curved crest on its head
    factMedium: Its crest may have been used to make sounds for communication
    factHard: Walked on two or four legs
  resultImage: {fileID: 257656704}
  backgroundImage: {fileID: 1537631772}
  musicSource: {fileID: 1499820774}
